generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum PermissionKey {
  DASHBOARD
  ROSTER
  ANALYTICS
  DAILY_TASKS
  SECRETARY
  INVENTORY
  BANK
  DISTRIBUTION
  USERS
}

enum InventoryAdjustmentType {
  STOCK_IN
  STOCK_OUT
  DISTRIBUTED
  CORRECTION
}

enum BankTransactionType {
  CREDIT
  DEBIT
}

enum BankMoneyType {
  CLEAN
  DIRTY
}

enum DistributionStatus {
  ASSIGNED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum RunnerDistributionStatus {
  ACTIVE
  PARTIAL
  CLEARED
  FAULTY
}

enum CollectionAction {
  PARTIAL_PAYMENT
  FULL_CLEAR
  FAULTY_CLEAR
}

enum CollectionLedgerStatus {
  PENDING
  DEPOSITED
}

enum RosterStatus {
  ACTIVE
  LOA
  INACTIVE
}

enum DailyTaskImportance {
  LOW
  MEDIUM
  HIGH
}

enum SecretaryMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum SecretaryRecordType {
  MEETING_MINUTES
  JOURNAL_ENTRY
  NOTICE
}

model User {
  id                     String            @id @default(cuid())
  email                  String            @unique
  passwordHash           String
  name                   String
  role                   Role              @default(USER)
  active                 Boolean           @default(true)
  permissions            UserPermission[]
  createdDistributions   Distribution[]    @relation("DistributionCreatedBy")
  assignedDistributions  Distribution[]    @relation("DistributionAssignedTo")
  createdRunnerDistributions RunnerDistribution[] @relation("RunnerDistributionCreatedBy")
  createdCollectionEntries DistributionCollection[] @relation("DistributionCollectionCreatedBy")
  createdTransactions    BankTransaction[] @relation("BankTransactionCreatedBy")
  createdDailyTasks      DailyTask[]       @relation("DailyTaskCreatedBy")
  dailyTaskCompletions   DailyTaskCompletion[]
  createdWeeklyTasks     WeeklyTask[]      @relation("WeeklyTaskCreatedBy")
  completedWeeklyTasks   WeeklyTaskCompletion[] @relation("WeeklyTaskCompletedBy")
  weeklyTaskAwards       WeeklyTaskAward[]
  createdSecretaryMeetings SecretaryMeeting[] @relation("SecretaryMeetingCreatedBy")
  createdSecretaryRecords SecretaryRecord[] @relation("SecretaryRecordCreatedBy")
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

model UserPermission {
  id        String        @id @default(cuid())
  userId    String
  key       PermissionKey
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, key])
}

model InventoryItem {
  id           String              @id @default(cuid())
  name         String
  sku          String?             @unique
  category     String?
  unit         String              @default("unit")
  quantity     Int                 @default(0)
  reorderLevel Int                 @default(0)
  notes        String?
  movements    InventoryMovement[]
  distributions Distribution[]
  runnerDistributions RunnerDistribution[] @relation("RunnerDistributionItem")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model InventoryMovement {
  id            String                  @id @default(cuid())
  itemId        String
  quantityDelta Int
  type          InventoryAdjustmentType
  reason        String?
  item          InventoryItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt     DateTime                @default(now())
}

model BankTransaction {
  id             String              @id @default(cuid())
  amount         Decimal             @db.Decimal(12, 2)
  type           BankTransactionType
  moneyType      BankMoneyType       @default(CLEAN)
  sourceSystem   String              @default("manual")
  description    String?
  createdById    String?
  distributionId String?             @unique
  createdBy      User?               @relation("BankTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  distribution   Distribution?       @relation(fields: [distributionId], references: [id], onDelete: SetNull)
  depositedCollections DistributionCollection[] @relation("CollectionDeposit")
  createdAt      DateTime            @default(now())
}

model Distribution {
  id              String             @id @default(cuid())
  itemId          String
  assignedToId    String
  createdById     String
  quantity        Int
  unitPrice       Decimal?           @db.Decimal(12, 2)
  amountCollected Decimal?           @db.Decimal(12, 2)
  status          DistributionStatus @default(ASSIGNED)
  notes           String?
  item            InventoryItem      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  assignedTo      User               @relation("DistributionAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  createdBy       User               @relation("DistributionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  bankTransaction BankTransaction?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Distributor {
  id            String               @id @default(cuid())
  name          String
  number        String
  active        Boolean              @default(true)
  distributions RunnerDistribution[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([name])
}

model RunnerDistribution {
  id             String                   @id @default(cuid())
  distributorId  String
  itemId         String
  createdById    String
  quantity       Int
  unitValue      Decimal                  @db.Decimal(12, 2)
  totalOwed      Decimal                  @db.Decimal(12, 2)
  amountReturned Decimal                  @default(0) @db.Decimal(12, 2)
  status         RunnerDistributionStatus @default(ACTIVE)
  notes          String?
  distributor    Distributor              @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  item           InventoryItem            @relation("RunnerDistributionItem", fields: [itemId], references: [id], onDelete: Restrict)
  createdBy      User                     @relation("RunnerDistributionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  collections    DistributionCollection[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([status])
  @@index([distributorId])
}

model DistributionCollection {
  id               String                 @id @default(cuid())
  distributionId   String
  createdById      String
  amount           Decimal                @db.Decimal(12, 2)
  action           CollectionAction
  status           CollectionLedgerStatus @default(PENDING)
  note             String?
  bankTransactionId String?
  depositedAt      DateTime?
  distribution     RunnerDistribution     @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("DistributionCollectionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  bankTransaction  BankTransaction?       @relation("CollectionDeposit", fields: [bankTransactionId], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status])
  @@index([distributionId])
}

model RosterMember {
  id          String       @id @default(cuid())
  name        String
  discordName String
  rank        String
  status      RosterStatus @default(ACTIVE)
  dateJoined  DateTime
  displayOrder Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([displayOrder])
}

model DailyTask {
  id             String                @id @default(cuid())
  title          String
  description    String?
  importance     DailyTaskImportance   @default(MEDIUM)
  active         Boolean               @default(true)
  createdById    String?
  createdBy      User?                 @relation("DailyTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completions    DailyTaskCompletion[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([active])
}

model DailyTaskCompletion {
  id            String      @id @default(cuid())
  taskId         String
  userId         String
  taskDay        String
  pointsAwarded  Int
  completedAt    DateTime   @default(now())
  task           DailyTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, taskDay])
  @@index([taskDay])
  @@index([userId, taskDay])
}

model WeeklyTask {
  id             String                 @id @default(cuid())
  title          String
  description    String?
  importance     DailyTaskImportance    @default(MEDIUM)
  active         Boolean                @default(true)
  createdById    String?
  createdBy      User?                  @relation("WeeklyTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completions    WeeklyTaskCompletion[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([active])
}

model WeeklyTaskCompletion {
  id             String      @id @default(cuid())
  taskId         String
  weekKey        String
  completedAt    DateTime    @default(now())
  completedById  String?
  task           WeeklyTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy    User?       @relation("WeeklyTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  awards         WeeklyTaskAward[]

  @@unique([taskId, weekKey])
  @@index([weekKey])
}

model WeeklyTaskAward {
  id            String               @id @default(cuid())
  completionId  String
  userId        String
  weekKey       String
  pointsAwarded Int
  createdAt     DateTime             @default(now())
  completion    WeeklyTaskCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([completionId, userId])
  @@index([userId])
  @@index([weekKey])
}

model SecretaryMeeting {
  id          String                 @id @default(cuid())
  title       String
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  audience    String?
  details     String?
  status      SecretaryMeetingStatus @default(SCHEDULED)
  createdById String?
  createdBy   User?                  @relation("SecretaryMeetingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  records     SecretaryRecord[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([startsAt])
  @@index([status])
}

model SecretaryRecord {
  id          String             @id @default(cuid())
  type        SecretaryRecordType
  title       String
  summary     String?
  content     String
  audience    String?
  meetingId   String?
  createdById String?
  meeting     SecretaryMeeting?  @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation("SecretaryRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([type])
  @@index([meetingId])
}
