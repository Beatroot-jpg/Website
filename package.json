{
  "name": "ops-inventory-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend-config": "node scripts/build-frontend-config.mjs",
    "dev": "node --watch backend/src/server.js",
    "start": "node backend/src/server.js",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema backend/prisma/schema.prisma",
    "seed": "node backend/scripts/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
